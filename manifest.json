{
    "manifest_version": 2,
    "name": "OverviewReviewer",
    "version": "1.0",

    "description": "Tool which verifies claims of Google's AI overview by reading given sources and assessing whether the overview is biased by the search terms.",

    "icons": {
        "96": "./icons/placeholder-96",
        "48": "./icons/placeholder-48"
    },

    "content_scripts": [
        {
            "matches": ["https://www.google.com/search*"],
            "js": ["./scripts/overviewReviewer.js"]
        },
        {
            "matches": ["http://127.0.0.1:9995/*"],
            "js": ["./scripts/chat.js"]
        }
    ],

    "permissions": [
    "activeTab",
    "https://ipinfo.io/*",
    "http://localhost/*",
    "http://127.0.0.1/*",
    "webNavigation"
    ],

    "browser_specific_settings": {
        "gecko": {
            "id": "overviewReviewer@tmo",
            "data_collection_permissions": {
                "required": ["none"]
            }
        }
    }
}